<Group view="presentation" inline-output="false" labelreference="L30161" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">To construct the Matrix from the Procesi and Schwarz approach:</Text-field>
</Input>
</Group></Presentation-Block>
<Group hide-input="false" labelreference="L30150" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Type:=C: 
n   :=2:

theta:=FundamentalInvariant(Type,n):

for i from 1 to n do
 for j from 1 to n do
    if i=j then
     D[i](x[j]):=x[j]
    else
     D[i](x[j]):=0
    fi;
 od;
od;

gradtheta:=[seq(&lt;seq(D[j](theta[i]),j=1..n)&gt;,i=1..n)]:

S:=Transpose(WeightMatrix(Type,n)).WeightMatrix(Type,n):

if Type=A then
 M:=-Matrix( n , (i,j) -&gt; InvariantRewrite(Type,n,expand( Transpose(gradtheta[i]).S.gradtheta[n+1-j] ) ) ) ;
elif Type=D and is(n,odd) then
 M:=-Matrix( n , (i,j) -&gt; InvariantRewrite(Type,n,expand( Transpose(gradtheta[i]).S.gradtheta[if j=n-1 then n elif j=n then n-1 else j fi] ) ) ) ;
elif Type=E and n=6 then
 M:=-Matrix( n , (i,j) -&gt; InvariantRewrite(Type,n,expand( Transpose(gradtheta[i]).S.gradtheta[if j=1 then 6 elif j=3 then 5 elif j=5 then 3 elif j=6 then 1 else j fi] ) ) ) ;
else
 M:=-Matrix( n , (i,j) -&gt; InvariantRewrite(Type,n,expand( Transpose(gradtheta[i]).S.gradtheta[    j] ) ) ) ;
fi;
</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L31075" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">with(plots):

chi:=u-&gt;subs(t=u,CharacteristicPolynomial(M,t)):

Condition[1]:=+      chi(0)     :
Condition[2]:=-coeff(chi(u),u  ):  <Font foreground="[128,128,128]"># alternating sign
</Font>              +coeff(chi(u),u^2):  <Font foreground="[128,128,128]"># should be 1

</Font>display([
  inequal({Condition[1]&gt;=0,Condition[2]&gt;=0},z[1]=-2..2,z[2]=-2..2,optionsfeasible = [color = red, transparency=0.5], optionsclosed = [color = red, thickness = 2], optionsexcluded = [color = &quot;WhiteSmoke&quot;])
],view=[-2..2,-2..2],<Font opaque="false" subscript="false" underline="false" superscript="false" bold="true" foreground="[120,0,14]" italic="false" executable="true" selection-placeholder="false" size="12" readonly="false" background="[255,255,255]" style="Help Maple Name" strikethrough="false" placeholder="false" family="Courier New" font_style_name="Help Maple Name">labels=[z[1]</Font>, z[2]<Font opaque="false" subscript="false" underline="false" superscript="false" bold="true" foreground="[120,0,14]" italic="false" executable="true" selection-placeholder="false" size="12" readonly="false" background="[255,255,255]" style="Help Maple Name" strikethrough="false" placeholder="false" family="Courier New" font_style_name="Help Maple Name">]</Font>,axes=boxed,scaling=constrained);</Text-field>
