<Section collapsed="true" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 1" layout="Heading 1">Symmetry Adaptation (Additive)</Text-field></Title><Presentation-Block>
<Group view="presentation" inline-output="false" labelreference="L37414" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group view="code" labelreference="L37450" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">interface(warnlevel=0):</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L37451" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">n:=3;
r:=2;</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L37436" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Big Rep

L:=[seq(op(ChebyshevLevel(C,n,i)),i=0..r)];
LL:=[seq([L[i],i],i=1..nops(L))]:

W:=RWeylGroupGen(A,n-1);

for i from 1 to nops(W) do
 LOrbit[i]:=map(l-&gt;convert(W[i].&lt;l&gt;,list),L); 
 LLOrbit[i]:=map(l-&gt;op(select(k-&gt;is(l=k[1]),LL))[2],LOrbit[i]);
 s[i]:=Matrix(map(l-&gt;[seq(`if`(j=l,1,0),j=1..nops(L))],LLOrbit[i]));
od:

BigRep:=[s[1]^2,s[2],s[1],s[2].s[1],s[1].s[2],s[1].s[2].s[1]];</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L37448" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">L</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L37447" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">MonomialBasis:=map(l-&gt;convert([seq(X[i]^l[i],i=1..nops(l))],`*`),L)</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L37446" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">convert(X[2]^2-X[1],list)</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L37440" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">map(l-&gt;convert(l,list),[op(X[2]^2-X[1])])</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L37453" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">factor(X[2]^2)</Text-field>
</Input>
</Group>
<Group view="code" labelreference="L37454" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
</Input>
</Group>
<Group view="code" labelreference="L37455" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L37437" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Irred Rep

s:=[Matrix([[1]]),Matrix([[1]])]:

Irrep[1]:=[s[1]^2,s[2],s[1],s[2].s[1],s[1].s[2],s[1].s[2].s[1]];


s:=ZWeylGroupGen(A,2):

Irrep[2]:=[s[1]^2,s[2],s[1],s[2].s[1],s[1].s[2],s[1].s[2].s[1]];


s:=[Matrix([[-1]]),Matrix([[-1]])]:

Irrep[3]:=[s[1]^2,s[2],s[1],s[2].s[1],s[1].s[2],s[1].s[2].s[1]];
</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L37429" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">X:=Transpose(Matrix(map(i-&gt;map(s-&gt;Trace(s),Irrep[i]),[1,2,3])));

<Font foreground="[128,0,0]">Phi:=&lt;map(s-&gt;Trace(s),BigRep)&gt;:

Multi:=</Font>LinearSolve(X,Phi);

Dim:=&lt;seq(X[1][i],i=1..nops(X[1]))&gt;;</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L37438" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">for i from 1 to ColumnDimension(X) do
 Proj[i]:=Dim[i]/nops(BigRep)*convert([seq(MatrixInverse(Irrep[i][j])[1,1]*BigRep[j],j=1..nops(BigRep))],`+`)
od:</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L37430" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L37431" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">S[1]:=[op(ColumnSpace(Proj[1]))]</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L37432" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">S[2]:=[ColumnSpace(Proj[2])[1],ColumnSpace(Proj[2])[2],2*ColumnSpace(Proj[2])[3]]</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L37428" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">T:=Matrix([op(S[1]),op(S[2])]);</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L37452" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Transpose(T).T</Text-field>
</Input>
